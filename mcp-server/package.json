{
  "name": "@komponentbibliotek/mcp-server",
  "version": "0.1.0",
  "description": "MCP-server for komponentbibliotek-flutter — komponent-API, migrering og dokumentasjonssøk",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "komponentbibliotek-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && cp -r src/data dist/",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "build-data": "tsx scripts/build-data.ts",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "minisearch": "^7.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
